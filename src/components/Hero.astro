---
---
<section class="hero" id="hero">
  <div class="bubbles" aria-hidden="true">
    <div class="bubble" style="--size: 60px; --left: 8%; --delay: 0s; --duration: 14s;"></div>
    <div class="bubble" style="--size: 35px; --left: 25%; --delay: 2s; --duration: 11s;"></div>
    <div class="bubble" style="--size: 80px; --left: 48%; --delay: 4s; --duration: 18s;"></div>
    <div class="bubble" style="--size: 25px; --left: 65%; --delay: 1s; --duration: 10s;"></div>
    <div class="bubble" style="--size: 50px; --left: 80%; --delay: 3s; --duration: 15s;"></div>
    <div class="bubble" style="--size: 70px; --left: 18%; --delay: 6s; --duration: 17s;"></div>
    <div class="bubble" style="--size: 40px; --left: 55%; --delay: 5s; --duration: 13s;"></div>
    <div class="bubble" style="--size: 30px; --left: 92%; --delay: 2.5s; --duration: 12s;"></div>
  </div>
  <div class="content">
    <h1 class="title">SodaPlay</h1>
    <p class="subtitle">属于打粉的专属游乐场</p>
  </div>
  <a class="scroll-hint" href="#games" aria-label="向下滚动">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(160deg, #5BB8A6 0%, #7DD3C5 30%, #A8E6CF 60%, #E8F5F1 100%);
    overflow: hidden;
  }

  .content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 0 24px;
  }

  .title {
    font-size: clamp(3rem, 12vw, 5.5rem);
    font-weight: 800;
    color: #FFFFFF;
    letter-spacing: 0.06em;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.08);
    line-height: 1.1;
  }

  .subtitle {
    margin-top: 16px;
    font-size: clamp(0.95rem, 3vw, 1.25rem);
    color: rgba(255, 255, 255, 0.88);
    font-weight: 400;
    letter-spacing: 0.12em;
  }

  .bubble {
    position: absolute;
    bottom: -120px;
    left: var(--left);
    width: var(--size);
    height: var(--size);
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.14);
    border: 1px solid rgba(255, 255, 255, 0.18);
    animation: float-up var(--duration) var(--delay) infinite ease-in;
  }

  @keyframes float-up {
    0% {
      transform: translateY(0) scale(0.4);
      opacity: 0;
    }
    10% {
      opacity: 1;
    }
    85% {
      opacity: 0.5;
    }
    100% {
      transform: translateY(-115vh) scale(1);
      opacity: 0;
    }
  }

  .scroll-hint {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255, 255, 255, 0.6);
    animation: bounce 2.4s infinite;
  }

  .scroll-hint:hover {
    color: rgba(255, 255, 255, 0.9);
  }

  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% {
      transform: translateX(-50%) translateY(0);
    }
    40% {
      transform: translateX(-50%) translateY(-10px);
    }
    60% {
      transform: translateX(-50%) translateY(-5px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .bubble {
      animation: none;
      opacity: 0.2;
      transform: scale(0.6);
    }
    .scroll-hint {
      animation: none;
    }
  }
</style>
