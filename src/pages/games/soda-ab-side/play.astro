---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { voteTopics } from '../../../data/votes';
---
<BaseLayout title="苏打AB面 - SodaPlay">
  <script type="application/json" id="vote-data" set:html={JSON.stringify(voteTopics)} />
  <div class="game-page">
    <header class="game-header">
      <a href="/games/soda-ab-side" class="back-btn" aria-label="返回">←</a>
      <span class="progress-text" id="progressText">第 1/5 题</span>
      <span class="voted-text" id="votedText">已投 0/5</span>
    </header>
    <div class="progress-bar">
      <div class="progress-fill" id="progressFill"></div>
    </div>

    <div class="game-content" id="gameContent">
      <div class="topic-section">
        <h2 class="topic-title" id="topicTitle"></h2>
        <p class="topic-desc" id="topicDesc"></p>
      </div>
      <div class="options-area">
        <button class="option-card" id="optionA">
          <div class="option-fill option-fill--a" id="fillA"></div>
          <div class="option-content">
            <div class="option-top">
              <span class="option-side option-side--a">A 面</span>
              <span class="option-pct option-pct--a" id="pctA" hidden></span>
            </div>
            <span class="option-title" id="titleA"></span>
            <span class="option-album" id="albumA"></span>
            <span class="option-count" id="countA" hidden></span>
          </div>
          <span class="option-badge" id="badgeA" hidden>你的选择</span>
        </button>
        <div class="vs-divider"><span class="vs-text">VS</span></div>
        <button class="option-card" id="optionB">
          <div class="option-fill option-fill--b" id="fillB"></div>
          <div class="option-content">
            <div class="option-top">
              <span class="option-side option-side--b">B 面</span>
              <span class="option-pct option-pct--b" id="pctB" hidden></span>
            </div>
            <span class="option-title" id="titleB"></span>
            <span class="option-album" id="albumB"></span>
            <span class="option-count" id="countB" hidden></span>
          </div>
          <span class="option-badge option-badge--b" id="badgeB" hidden>你的选择</span>
        </button>
      </div>
      <p class="vote-total" id="voteTotal"></p>
      <div class="nav-btns">
        <button class="nav-btn nav-btn--prev" id="prevBtn" hidden>← 上一题</button>
        <button class="nav-btn nav-btn--next" id="nextBtn">下一题 →</button>
      </div>
    </div>
  </div>
  <div class="toast" id="toast"></div>
</BaseLayout>

<style is:global>
  .game-page {
    min-height: 100vh;
    min-height: 100dvh;
    background: var(--color-bg);
    display: flex;
    flex-direction: column;
  }

  .game-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    background: #FFFFFF;
    border-bottom: 1px solid #F0F0F0;
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .back-btn {
    font-size: 1.2rem;
    color: var(--color-text-light);
    min-width: 36px;
    min-height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
  }

  .back-btn:hover {
    color: var(--color-text);
  }

  .progress-text {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .voted-text {
    font-size: 0.82rem;
    font-weight: 600;
    color: #9B7FD4;
  }

  .progress-bar {
    height: 3px;
    background: #F0F0F0;
  }

  .progress-fill {
    height: 100%;
    background: #9B7FD4;
    transition: width 0.4s ease;
    border-radius: 0 2px 2px 0;
  }

  .game-content {
    flex: 1;
    padding: 24px 16px;
    max-width: 600px;
    width: 100%;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
  }

  .topic-section {
    text-align: center;
    margin-bottom: 28px;
  }

  .topic-title {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--color-text);
    margin-bottom: 8px;
    letter-spacing: 0.02em;
  }

  .topic-desc {
    font-size: 0.92rem;
    color: var(--color-text-light);
    line-height: 1.6;
  }

  .options-area {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 16px;
  }

  .option-card {
    position: relative;
    width: 100%;
    padding: 20px;
    background: #FFFFFF;
    border: 2px solid #E8ECEF;
    border-radius: 14px;
    text-align: center;
    cursor: pointer;
    transition: all 0.25s ease;
    font-family: inherit;
    box-shadow: var(--shadow-sm);
    overflow: hidden;
  }

  .option-card:hover:not(.voted) {
    border-color: #9B7FD4;
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(155, 127, 212, 0.12);
  }

  .option-card:active:not(.voted) {
    transform: scale(0.98);
  }

  .option-fill {
    position: absolute;
    inset: 0;
    width: 0;
    transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 0;
    pointer-events: none;
  }

  .option-fill--a {
    background: linear-gradient(90deg, rgba(155, 127, 212, 0.12), rgba(155, 127, 212, 0.06));
  }

  .option-fill--b {
    background: linear-gradient(90deg, rgba(232, 154, 154, 0.12), rgba(232, 154, 154, 0.06));
  }

  .option-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .option-top {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .option-side {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .option-side--a { color: #9B7FD4; }
  .option-side--b { color: #E89A9A; }

  .option-pct {
    font-size: 0.78rem;
    font-weight: 800;
  }

  .option-pct--a { color: #9B7FD4; }
  .option-pct--b { color: #E89A9A; }
  .option-pct[hidden] { display: none; }

  .option-title {
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--color-text);
  }

  .option-album {
    font-size: 0.8rem;
    color: var(--color-text-light);
  }

  .option-count {
    font-size: 0.75rem;
    color: var(--color-text-light);
  }

  .option-count[hidden] { display: none; }

  .option-badge {
    position: absolute;
    top: 0;
    right: 14px;
    padding: 3px 10px 2px;
    background: #9B7FD4;
    color: #FFFFFF;
    font-size: 0.68rem;
    font-weight: 700;
    border-radius: 0 0 8px 8px;
    z-index: 2;
  }

  .option-badge--b { background: #E89A9A; }
  .option-badge[hidden] { display: none; }

  .option-card.voted { cursor: pointer; }
  .option-card.voted:hover { border-color: #C4B0E0; }

  .option-card.chosen {
    border-color: #9B7FD4;
    box-shadow: 0 4px 20px rgba(155, 127, 212, 0.18);
  }

  .option-card.chosen-b {
    border-color: #E89A9A;
    box-shadow: 0 4px 20px rgba(232, 154, 154, 0.18);
  }

  .option-card.dimmed { opacity: 0.6; }
  .option-card.dimmed:hover { opacity: 0.85; }

  .vs-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 32px;
    position: relative;
    z-index: 1;
  }

  .vs-text {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: #FFFFFF;
    border: 2px solid #E8ECEF;
    color: #9B7FD4;
    font-size: 0.72rem;
    font-weight: 800;
    border-radius: 50%;
  }

  .vote-total {
    text-align: center;
    font-size: 0.8rem;
    color: var(--color-text-light);
    margin-bottom: 20px;
  }

  .vote-total[hidden] { display: none; }

  .nav-btns {
    display: flex;
    gap: 12px;
    margin-top: auto;
    padding-top: 16px;
  }

  .nav-btn {
    flex: 1;
    padding: 14px;
    border: none;
    border-radius: 12px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s, opacity 0.2s;
    font-family: inherit;
  }

  .nav-btn:active { transform: scale(0.98); }

  .nav-btn[hidden] { display: none; }

  .nav-btn--prev {
    background: #F0EAF8;
    color: #7B5EAA;
  }

  .nav-btn--prev:hover {
    background: #E4DCF2;
  }

  .nav-btn--next {
    background: #9B7FD4;
    color: #FFFFFF;
  }

  .nav-btn--next:hover {
    background: #8A6EC3;
  }

  .toast {
    position: fixed;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    padding: 10px 24px;
    background: rgba(45, 30, 70, 0.85);
    color: #FFFFFF;
    font-size: 0.88rem;
    font-weight: 600;
    border-radius: 50px;
    opacity: 0;
    pointer-events: none;
    transition: all 0.3s ease;
    z-index: 200;
    white-space: nowrap;
  }

  .toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  @media (min-width: 640px) {
    .game-content {
      padding: 36px 24px;
    }

    .option-title {
      font-size: 1.3rem;
    }

    .option-card {
      padding: 24px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .option-fill {
      transition: none;
    }
  }
</style>

<script>
  import type { VoteTopic, VoteStats } from '../../../data/votes';
  import { initSeedStats, submitVote, getPlayerStatus } from '../../../lib/cloudbase';

  const topics: VoteTopic[] = JSON.parse(
    (document.getElementById('vote-data') as HTMLScriptElement).textContent || '[]'
  );

  const total = topics.length;

  const progressText = document.getElementById('progressText')!;
  const votedText = document.getElementById('votedText')!;
  const progressFill = document.getElementById('progressFill')!;
  const topicTitle = document.getElementById('topicTitle')!;
  const topicDesc = document.getElementById('topicDesc')!;
  const optionA = document.getElementById('optionA') as HTMLButtonElement;
  const optionB = document.getElementById('optionB') as HTMLButtonElement;
  const titleA = document.getElementById('titleA')!;
  const titleB = document.getElementById('titleB')!;
  const albumA = document.getElementById('albumA')!;
  const albumB = document.getElementById('albumB')!;
  const fillA = document.getElementById('fillA') as HTMLElement;
  const fillB = document.getElementById('fillB') as HTMLElement;
  const pctA = document.getElementById('pctA') as HTMLElement;
  const pctB = document.getElementById('pctB') as HTMLElement;
  const countA = document.getElementById('countA') as HTMLElement;
  const countB = document.getElementById('countB') as HTMLElement;
  const badgeA = document.getElementById('badgeA') as HTMLElement;
  const badgeB = document.getElementById('badgeB') as HTMLElement;
  const voteTotal = document.getElementById('voteTotal') as HTMLElement;
  const prevBtn = document.getElementById('prevBtn') as HTMLButtonElement;
  const nextBtn = document.getElementById('nextBtn') as HTMLButtonElement;
  const gameContent = document.getElementById('gameContent')!;
  const toastEl = document.getElementById('toast')!;

  let current = 0;
  let voted = 0;
  let choice: string | null = null;
  let stats: VoteStats | null = null;
  let toastTimer: ReturnType<typeof setTimeout>;
  const choices: Record<string, string> = {};

  function showToast(msg: string) {
    toastEl.textContent = msg;
    toastEl.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => toastEl.classList.remove('show'), 2000);
  }

  function updateHeader() {
    progressText.textContent = `第 ${current + 1}/${total} 题`;
    progressFill.style.width = `${((current + 1) / total) * 100}%`;
    votedText.textContent = `已投 ${voted}/${total}`;
  }

  function resetOptions() {
    optionA.className = 'option-card';
    optionB.className = 'option-card';
    fillA.style.width = '0';
    fillB.style.width = '0';
    pctA.hidden = true;
    pctB.hidden = true;
    countA.hidden = true;
    countB.hidden = true;
    badgeA.hidden = true;
    badgeB.hidden = true;
    voteTotal.hidden = true;
  }

  function applyResults() {
    const s = stats!;
    const t = s.total || 1;
    const percentA = Math.round((s.countA / t) * 100);
    const percentB = 100 - percentA;

    pctA.textContent = `${percentA}%`;
    pctB.textContent = `${percentB}%`;
    pctA.hidden = false;
    pctB.hidden = false;

    fillA.style.width = `${percentA}%`;
    fillB.style.width = `${percentB}%`;

    countA.textContent = `${s.countA} 票`;
    countB.textContent = `${s.countB} 票`;
    countA.hidden = false;
    countB.hidden = false;

    badgeA.hidden = choice !== 'a';
    badgeB.hidden = choice !== 'b';

    optionA.className = 'option-card voted' + (choice === 'a' ? ' chosen' : ' dimmed');
    optionB.className = 'option-card voted' + (choice === 'b' ? ' chosen-b' : ' dimmed');

    voteTotal.textContent = `共 ${s.total} 人参与`;
    voteTotal.hidden = false;
  }

  function updateNav() {
    prevBtn.hidden = current === 0;
    nextBtn.hidden = current === total - 1;
  }

  async function renderTopic() {
    const topic = topics[current];

    updateHeader();
    updateNav();

    topicTitle.textContent = topic.topic;
    topicDesc.textContent = topic.description;

    titleA.textContent = topic.options[0].title;
    albumA.textContent = `《${topic.options[0].album}》`;
    titleB.textContent = topic.options[1].title;
    albumB.textContent = `《${topic.options[1].album}》`;

    stats = await getPlayerStatus(topic.id);
    choice = stats.playerChoice;

    if (choice) {
      applyResults();
    } else {
      resetOptions();
      voteTotal.textContent = `共 ${stats.total} 人参与`;
      voteTotal.hidden = false;
    }

    gameContent.scrollIntoView({ block: 'start' });
  }

  async function handleVote(optionId: string) {
    if (choice === optionId) return;

    const topic = topics[current];
    const wasVoted = !!choice;

    stats = await submitVote(topic.id, optionId);
    choice = optionId;

    if (!wasVoted) {
      voted++;
    }
    choices[topic.id] = optionId;
    updateHeader();

    applyResults();
    showToast(wasVoted ? '已更新选择' : '投票成功');
  }

  optionA.addEventListener('click', () => handleVote('a'));
  optionB.addEventListener('click', () => handleVote('b'));

  prevBtn.addEventListener('click', () => {
    if (current > 0) {
      current--;
      renderTopic();
    }
  });

  nextBtn.addEventListener('click', () => {
    if (current < total - 1) {
      current++;
      renderTopic();
    }
  });

  initSeedStats();

  async function init() {
    for (const t of topics) {
      const s = await getPlayerStatus(t.id);
      if (s.playerChoice) {
        choices[t.id] = s.playerChoice;
      }
    }
    voted = Object.keys(choices).length;
    current = 0;
    renderTopic();
  }

  init();
</script>
