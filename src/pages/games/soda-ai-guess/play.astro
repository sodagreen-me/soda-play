---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { allSongs } from '../../../data/songs';
import { albumCovers } from '../../../data/albumCovers';
---
<BaseLayout title="苏打AI猜 - SodaPlay">
  <script type="application/json" id="song-data" set:html={JSON.stringify(allSongs)} />
  <script type="application/json" id="album-cover-data" set:html={JSON.stringify(albumCovers)} />
  <div class="game-page">
    <header class="game-header">
      <a href="/games/soda-ai-guess" class="back-btn" aria-label="返回">←</a>
      <span class="progress-text" id="progressText">第 1/15 题</span>
      <span class="score-text" id="scoreText">0 分</span>
    </header>
    <div class="progress-bar">
      <div class="progress-fill" id="progressFill"></div>
    </div>

    <div class="game-content" id="gameContent">
      <div class="ai-section">
        <div class="ai-avatar">🤖</div>
        <div class="ai-bubble">
          <p class="ai-label">AI 说：</p>
          <p class="ai-text" id="aiText"></p>
          <div class="album-hint-card" id="albumHintCard" hidden>
            <img class="album-hint-cover" id="albumHintCover" alt="" loading="lazy" />
            <p class="album-hint" id="albumHint"></p>
          </div>
        </div>
      </div>
      <div class="options-list" id="optionsList"></div>
      <p class="album-info" id="albumInfo"></p>
      <div class="answer-explanation" id="answerExplanation" hidden>
        <span class="explanation-label">AI 解析：</span>
        <span id="explanationText"></span>
      </div>
      <details class="lyrics-panel" id="lyricsDetails" hidden>
        <summary>查看完整版歌词</summary>
        <pre class="lyrics-text" id="lyricsText"></pre>
      </details>
      <button class="next-btn" id="nextBtn">下一题 →</button>
    </div>

    <div class="result-overlay" id="resultOverlay">
      <div class="result-card">
        <div class="result-emoji" id="resultEmoji"></div>
        <h2 class="result-title">游戏结束！</h2>
        <p class="result-score" id="resultScore"></p>
        <p class="result-msg" id="resultMsg"></p>
        <button class="replay-btn" id="replayBtn">再来一局</button>
        <a href="/games/soda-ai-guess" class="back-link">返回游戏主页</a>
      </div>
    </div>
  </div>
</BaseLayout>

<style is:global>
  .game-page {
    min-height: 100vh;
    min-height: 100dvh;
    background: var(--color-bg);
    display: flex;
    flex-direction: column;
  }

  .game-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    background: #FFFFFF;
    border-bottom: 1px solid #F0F0F0;
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .back-btn {
    font-size: 1.2rem;
    color: var(--color-text-light);
    min-width: 36px;
    min-height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
  }

  .back-btn:hover {
    color: var(--color-text);
  }

  .progress-text {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .score-text {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  .progress-bar {
    height: 3px;
    background: #F0F0F0;
  }

  .progress-fill {
    height: 100%;
    background: var(--color-primary);
    transition: width 0.4s ease;
    border-radius: 0 2px 2px 0;
  }

  .game-content {
    flex: 1;
    padding: 24px 16px;
    max-width: 600px;
    width: 100%;
    margin: 0 auto;
  }

  .ai-section {
    display: flex;
    gap: 12px;
    margin-bottom: 28px;
  }

  .ai-avatar {
    width: 40px;
    height: 40px;
    background: var(--color-primary-light);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.3rem;
    flex-shrink: 0;
  }

  .ai-bubble {
    flex: 1;
    background: #FFFFFF;
    border-radius: 16px;
    border-top-left-radius: 4px;
    padding: 16px;
    box-shadow: var(--shadow-sm);
  }

  .ai-label {
    font-size: 0.75rem;
    color: var(--color-primary);
    font-weight: 600;
    margin-bottom: 8px;
  }

  .ai-text {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-text);
  }

  .album-hint-card {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 10px;
    padding-top: 10px;
    border-top: 1px dashed #D8E8E2;
  }

  .album-hint-card[hidden] {
    display: none;
  }

  .album-hint-cover {
    width: 52px;
    height: 52px;
    border-radius: 10px;
    object-fit: cover;
    box-shadow: 0 4px 14px rgba(91, 184, 166, 0.18);
    flex-shrink: 0;
  }

  .album-hint {
    font-size: 0.82rem;
    color: var(--color-primary);
    font-weight: 600;
  }

  .options-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 8px;
  }

  .album-info {
    text-align: center;
    font-size: 0.82rem;
    color: var(--color-text-light);
    margin-bottom: 12px;
    min-height: 1.4em;
  }

  .answer-explanation {
    padding: 12px 14px;
    margin-bottom: 12px;
    background: #F7FBF8;
    border: 1px solid #DCEFE3;
    border-radius: 12px;
    color: var(--color-text);
    font-size: 0.84rem;
    line-height: 1.6;
  }

  .answer-explanation[hidden] {
    display: none;
  }

  .explanation-label {
    color: var(--color-primary-dark);
    font-weight: 700;
  }

  .lyrics-panel {
    margin-bottom: 20px;
    background: #FFFFFF;
    border: 1px solid #E8ECEF;
    border-radius: 12px;
    box-shadow: var(--shadow-sm);
  }

  .lyrics-panel[hidden] {
    display: none;
  }

  .lyrics-panel summary {
    padding: 12px 14px;
    color: var(--color-primary-dark);
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .lyrics-text {
    max-height: 320px;
    margin: 0;
    padding: 0 14px 14px;
    overflow: auto;
    color: var(--color-text);
    font-family: inherit;
    font-size: 0.86rem;
    line-height: 1.75;
    white-space: pre-wrap;
  }

  .option {
    width: 100%;
    padding: 14px 16px;
    background: #FFFFFF;
    border: 2px solid #E8ECEF;
    border-radius: 12px;
    font-size: 0.95rem;
    color: var(--color-text);
    cursor: pointer;
    transition: all 0.25s ease;
    text-align: left;
    font-family: inherit;
    min-height: 52px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .option-cover {
    width: 52px;
    height: 52px;
    border-radius: 10px;
    object-fit: cover;
    box-shadow: 0 3px 10px rgba(26, 44, 40, 0.12);
    flex-shrink: 0;
  }

  .option-text {
    flex: 1;
    min-width: 0;
  }

  .option:hover:not(.disabled) {
    border-color: var(--color-primary);
    background: var(--color-primary-light);
  }

  .option:active:not(.disabled) {
    transform: scale(0.98);
  }

  .option.correct {
    border-color: #66BB6A;
    background: #E8F5E9;
    color: #2E7D32;
    animation: option-pulse 0.3s ease;
  }

  .option.wrong {
    border-color: #EF5350;
    background: #FFEBEE;
    color: #C62828;
    animation: option-shake 0.4s ease;
  }

  .option.disabled {
    cursor: default;
    opacity: 0.55;
  }

  .option.disabled.correct {
    opacity: 1;
  }

  @keyframes option-pulse {
    50% { transform: scale(1.02); }
  }

  @keyframes option-shake {
    20% { transform: translateX(-4px); }
    40% { transform: translateX(4px); }
    60% { transform: translateX(-3px); }
    80% { transform: translateX(3px); }
  }

  .next-btn {
    display: block;
    width: 100%;
    padding: 14px;
    background: var(--color-primary);
    color: #FFFFFF;
    font-size: 1rem;
    font-weight: 600;
    border: none;
    border-radius: 12px;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    font-family: inherit;
  }

  .next-btn:hover {
    background: var(--color-primary-dark);
  }

  .next-btn:active {
    transform: scale(0.98);
  }

  .result-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
    z-index: 100;
    animation: fade-in 0.3s ease;
  }

  .result-card {
    background: #FFFFFF;
    border-radius: 24px;
    padding: 40px 32px;
    text-align: center;
    max-width: 380px;
    width: 100%;
    box-shadow: var(--shadow-lg);
    animation: card-pop 0.4s ease;
  }

  .result-emoji {
    font-size: 4rem;
    margin-bottom: 12px;
  }

  .result-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 8px;
  }

  .result-score {
    font-size: 1.05rem;
    color: var(--color-text-light);
    margin-bottom: 8px;
  }

  .result-msg {
    font-size: 1rem;
    color: var(--color-primary-dark);
    font-weight: 600;
    margin-bottom: 28px;
  }

  .replay-btn {
    display: block;
    width: 100%;
    padding: 14px;
    background: var(--color-primary);
    color: #FFFFFF;
    font-size: 1rem;
    font-weight: 600;
    border: none;
    border-radius: 50px;
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
    font-family: inherit;
    margin-bottom: 16px;
  }

  .replay-btn:hover {
    background: var(--color-primary-dark);
  }

  .replay-btn:active {
    transform: scale(0.98);
  }

  .back-link {
    font-size: 0.85rem;
    color: var(--color-text-light);
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--color-text);
  }

  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes card-pop {
    from { transform: scale(0.9); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  @media (min-width: 640px) {
    .game-content {
      padding: 40px 24px;
    }

    .ai-text {
      font-size: 1rem;
    }

    .option {
      padding: 18px 24px;
      font-size: 1rem;
    }

    .option-cover {
      width: 58px;
      height: 58px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .option.correct,
    .option.wrong {
      animation: none;
    }
    .result-overlay,
    .result-card {
      animation: none;
    }
  }
</style>

<script>
  interface AiDescription {
    text: string;
    explanation: string;
  }

  interface Song {
    name: string;
    album: string;
    lyrics: string;
    aiDescription: [AiDescription, AiDescription, AiDescription];
  }

  interface Question {
    song: Song;
    options: Song[];
    aiDescription: AiDescription;
  }

  type Difficulty = 'normal' | 'hard';

  const QUESTIONS_PER_ROUND = 15;

  const allSongs: Song[] = JSON.parse(
    document.getElementById("song-data")!.textContent!,
  );
  const albumCovers: Record<string, string> = JSON.parse(
    document.getElementById("album-cover-data")!.textContent!,
  );

  function getDifficulty(): Difficulty {
    const params = new URLSearchParams(window.location.search);
    return params.get('mode') === 'normal' ? 'normal' : 'hard';
  }

  const difficulty: Difficulty = getDifficulty();

  function shuffle<T>(arr: T[]): T[] {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  function pickAiDescription(descriptions: Song["aiDescription"]): AiDescription {
    return descriptions[Math.floor(Math.random() * descriptions.length)];
  }

  function generateHardQuestions(): Question[] {
    const picked = shuffle(allSongs).slice(0, QUESTIONS_PER_ROUND);
    return picked.map((song) => {
      const others = allSongs.filter((s) => s.name !== song.name);
      const distractors = shuffle(others).slice(0, 3);
      const options = shuffle([song, ...distractors]);
      return {
        song,
        options,
        aiDescription: pickAiDescription(song.aiDescription),
      };
    });
  }

  function generateNormalQuestions(): Question[] {
    const albumMap = new Map<string, Song[]>();
    for (const song of allSongs) {
      const list = albumMap.get(song.album) ?? [];
      list.push(song);
      albumMap.set(song.album, list);
    }

    const eligibleAlbums = [...albumMap.entries()]
      .filter(([, songs]) => songs.length >= 4)
      .map(([album]) => album);

    const eligibleSongs = eligibleAlbums.flatMap((album) => albumMap.get(album)!);
    const pickedSongs = shuffle(eligibleSongs).slice(0, QUESTIONS_PER_ROUND);

    const questions: Question[] = pickedSongs.map((song) => {
      const songsInAlbum = albumMap.get(song.album)!;
      const others = songsInAlbum.filter((s) => s.name !== song.name);
      const distractors = shuffle(others).slice(0, 3);
      const options = shuffle([song, ...distractors]);
      return {
        song,
        options,
        aiDescription: pickAiDescription(song.aiDescription),
      };
    });

    return shuffle(questions);
  }

  function generateQuestions(): Question[] {
    return difficulty === 'normal' ? generateNormalQuestions() : generateHardQuestions();
  }

  const progressText = document.getElementById("progressText")!;
  const scoreText = document.getElementById("scoreText")!;
  const progressFill = document.getElementById("progressFill")!;
  const aiText = document.getElementById("aiText")!;
  const albumHintCard = document.getElementById("albumHintCard")!;
  const albumHintCover = document.getElementById("albumHintCover") as HTMLImageElement;
  const albumHint = document.getElementById("albumHint")!;
  const optionsList = document.getElementById("optionsList")!;
  const albumInfo = document.getElementById("albumInfo")!;
  const answerExplanation = document.getElementById("answerExplanation")!;
  const explanationText = document.getElementById("explanationText")!;
  const lyricsDetails = document.getElementById(
    "lyricsDetails",
  ) as HTMLDetailsElement;
  const lyricsText = document.getElementById("lyricsText")!;
  const nextBtn = document.getElementById("nextBtn")!;
  const gameContent = document.getElementById("gameContent")!;
  const resultOverlay = document.getElementById("resultOverlay")!;
  const resultEmoji = document.getElementById("resultEmoji")!;
  const resultScore = document.getElementById("resultScore")!;
  const resultMsg = document.getElementById("resultMsg")!;
  const replayBtn = document.getElementById("replayBtn")!;

  let questions: Question[] = [];
  let current = 0;
  let score = 0;
  let answered = false;

  function resetLyricsPanel() {
    lyricsText.textContent = "";
    lyricsText.scrollTop = 0;
    lyricsDetails.scrollTop = 0;
    lyricsDetails.hidden = true;
    lyricsDetails.open = false;
  }

  function getAlbumCover(album: string): string | undefined {
    return albumCovers[album];
  }

  function createCover(album: string, className: string): HTMLImageElement | null {
    const src = getAlbumCover(album);
    if (!src) return null;

    const img = document.createElement("img");
    img.className = className;
    img.src = src;
    img.alt = `《${album}》专辑封面`;
    img.loading = "lazy";
    return img;
  }

  function init() {
    questions = generateQuestions();
    current = 0;
    score = 0;
    answered = false;
    scoreText.textContent = "0 分";
    gameContent.style.display = "";
    resultOverlay.style.display = "none";
    renderQuestion();
  }

  function renderQuestion() {
    const q = questions[current];
    const total = questions.length;

    progressText.textContent = `第 ${current + 1}/${total} 题`;
    progressFill.style.width = `${((current + 1) / total) * 100}%`;
    aiText.textContent = q.aiDescription.text;
    if (difficulty === 'normal') {
      const coverSrc = getAlbumCover(q.song.album);
      if (coverSrc) {
        albumHintCover.src = coverSrc;
        albumHintCover.alt = `《${q.song.album}》专辑封面`;
        albumHintCover.hidden = false;
      } else {
        albumHintCover.hidden = true;
      }
      albumHint.textContent = `💡 提示：这首歌出自专辑《${q.song.album}》`;
      albumHintCard.hidden = false;
    } else {
      albumHintCard.hidden = true;
    }
    albumInfo.textContent = "";
    explanationText.textContent = "";
    answerExplanation.hidden = true;
    resetLyricsPanel();
    gameContent.scrollIntoView({ block: "start" });

    optionsList.innerHTML = "";
    q.options.forEach((opt) => {
      const btn = document.createElement("button");
      btn.className = "option";

      if (difficulty === 'hard') {
        const cover = createCover(opt.album, "option-cover");
        if (cover) btn.appendChild(cover);
      }

      const text = document.createElement("span");
      text.className = "option-text";
      text.textContent = opt.name;
      btn.appendChild(text);

      btn.addEventListener("click", () =>
        handleAnswer(btn, opt.name, q.song.name, q.song.album),
      );
      optionsList.appendChild(btn);
    });

    nextBtn.style.display = "none";
    answered = false;
  }

  function handleAnswer(
    btn: HTMLButtonElement,
    selected: string,
    correct: string,
    album: string,
  ) {
    if (answered) return;
    answered = true;

    const allBtns =
      optionsList.querySelectorAll<HTMLButtonElement>(".option");
    allBtns.forEach((b) => {
      b.classList.add("disabled");
      if (b.querySelector(".option-text")?.textContent === correct) {
        b.classList.add("correct");
      }
    });

    if (selected === correct) {
      score++;
      scoreText.textContent = `${score} 分`;
    } else {
      btn.classList.add("wrong");
    }

    albumInfo.textContent = `🎵 出自专辑《${album}》`;
    explanationText.textContent = questions[current].aiDescription.explanation;
    answerExplanation.hidden = false;
    lyricsText.textContent = questions[current].song.lyrics;
    lyricsText.scrollTop = 0;
    lyricsDetails.scrollTop = 0;
    lyricsDetails.hidden = false;
    lyricsDetails.open = false;

    const isLast = current >= questions.length - 1;
    nextBtn.style.display = "block";
    nextBtn.textContent = isLast ? "查看结果" : "下一题 →";
  }

  function showResult() {
    gameContent.style.display = "none";
    resultOverlay.style.display = "flex";

    const total = questions.length;
    resultScore.textContent = `你答对了 ${score}/${total} 题`;

    if (score === total) {
      resultEmoji.textContent = "🏆";
      resultMsg.textContent = "你是苏打绿本人吧！";
    } else if (score >= total - 1) {
      resultEmoji.textContent = "🎉";
      resultMsg.textContent = "资深打粉认证！";
    } else if (score >= total / 2) {
      resultEmoji.textContent = "🎵";
      resultMsg.textContent = "还需要多听听歌哦～";
    } else {
      resultEmoji.textContent = "🤔";
      resultMsg.textContent = "你确定你是打粉吗？";
    }
  }

  nextBtn.addEventListener("click", () => {
    current++;
    if (current >= questions.length) {
      showResult();
    } else {
      renderQuestion();
    }
  });

  replayBtn.addEventListener("click", init);

  init();
</script>
