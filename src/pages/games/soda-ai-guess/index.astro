---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---
<BaseLayout title="苏打AI猜 - SodaPlay">
  <div class="page">
    <a class="back" href="/">← 返回</a>
    <div class="card">
      <div class="icon">🤖</div>
      <h1 class="title">苏打AI猜</h1>
      <p class="desc">AI 会用它的方式描述一首苏打绿的歌，<br/>你能猜出是哪首吗？</p>
      <ul class="rules">
        <li>每局共 <strong>15 题</strong>，从苏打绿歌曲库中随机抽取</li>
        <li>AI 会给出一段趣味描述，从 4 个选项中选出正确的歌名</li>
        <li>答对加分，答错会显示正确答案和 AI 解析</li>
        <li>全部作答后查看最终成绩，看看你的脑洞和直觉能不能接上 AI 的频率～</li>
      </ul>
      <div class="difficulty-section">
        <p class="difficulty-label">选择难度</p>
        <div class="difficulty-options">
          <a class="diff-btn" href="/games/soda-ai-guess/play?mode=normal">
            <span class="diff-icon">🎵</span>
            <span class="diff-name">普通</span>
            <span class="diff-desc">提示专辑，同专辑选歌</span>
          </a>
          <a class="diff-btn diff-btn--hard" href="/games/soda-ai-guess/play?mode=hard">
            <span class="diff-icon">🔥</span>
            <span class="diff-name">困难</span>
            <span class="diff-desc">无提示，全曲库选歌</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 24px 16px;
    background: linear-gradient(160deg, #5BB8A6 0%, #7DD3C5 30%, #A8E6CF 60%, #E8F5F1 100%);
  }

  .back {
    position: absolute;
    top: 20px;
    left: 20px;
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .back:hover {
    color: #FFFFFF;
  }

  .card {
    text-align: center;
    background: var(--color-surface);
    border-radius: 24px;
    padding: 48px 32px;
    max-width: 400px;
    width: 100%;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.1);
  }

  .icon {
    font-size: 4rem;
    margin-bottom: 16px;
  }

  .title {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-text);
    letter-spacing: 0.04em;
  }

  .desc {
    margin-top: 16px;
    font-size: 0.95rem;
    color: var(--color-text-light);
    line-height: 1.7;
  }

  .rules {
    margin-top: 20px;
    padding: 0;
    list-style: none;
    text-align: left;
  }

  .rules li {
    position: relative;
    padding: 8px 0 8px 20px;
    font-size: 0.88rem;
    color: var(--color-text-light);
    line-height: 1.6;
  }

  .rules li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 15px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
  }

  .rules strong {
    color: var(--color-text);
  }

  .difficulty-section {
    margin-top: 28px;
    width: 100%;
  }

  .difficulty-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-light);
    margin-bottom: 12px;
  }

  .difficulty-options {
    display: flex;
    gap: 12px;
  }

  .diff-btn {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 18px 12px;
    background: #F5F9F8;
    border: 2px solid #E0EDE8;
    border-radius: 16px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .diff-btn:hover {
    border-color: var(--color-primary);
    background: var(--color-primary-light);
    transform: translateY(-2px);
  }

  .diff-btn:active {
    transform: scale(0.97);
  }

  .diff-btn--hard {
    background: #FFF8F5;
    border-color: #F0E0D8;
  }

  .diff-btn--hard:hover {
    border-color: #E8734A;
    background: #FFF0E8;
  }

  .diff-icon {
    font-size: 1.5rem;
  }

  .diff-name {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .diff-btn--hard .diff-name {
    color: #D4532A;
  }

  .diff-desc {
    font-size: 0.75rem;
    color: var(--color-text-light);
    line-height: 1.4;
  }

  @media (min-width: 640px) {
    .card {
      padding: 56px 40px;
    }

    .title {
      font-size: 2.4rem;
    }
  }
</style>
